# Supabase → Project Settings → API → "Project URL" (must end with .supabase.co)
# NOT the browser link to supabase.com/dashboard/...
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

