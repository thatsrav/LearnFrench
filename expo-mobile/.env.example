# Copy to .env and fill from Supabase Dashboard → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional: same host as french-scorer-web VITE_API_BASE_URL — enables OpenAI HD TTS on device
# when the server has OPENAI_API_KEY (POST /api/tts/french). Otherwise uses improved on-device voices.
# EXPO_PUBLIC_API_BASE_URL=http://192.168.x.x:8787
